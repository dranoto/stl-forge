# RunPod Serverless API credentials — DO NOT COMMIT
# Copy this file to `.env` and fill in the values.

# RunPod API key (https://runpod.io/console/user/settings)
RUNPOD_API_KEY=rp_xxxxxxxxxxxxxxxxxxxxxxxx

# RunPod serverless endpoint ID (created from this image in the RunPod console)
STL_FORGE_ENDPOINT_ID=<your-endpoint-id>

# --- Optional: S3-compatible storage for >20MB outputs (>~150k faces) ---
# The handler uploads STLs larger than 7 MB base64 to this bucket and returns
# a 24h presigned URL instead of an inline base64 blob. Required for high-poly
# outputs. Leave blank to use the inline-only path (caps at ~100k faces).

# Endpoint URL (S3-compatible)
BUCKET_ENDPOINT_URL=

# Access Key ID
BUCKET_ACCESS_KEY_ID=

# Secret Access Key
BUCKET_SECRET_ACCESS_KEY=

# Bucket name
BUCKET_NAME=stl-forge-tmp
